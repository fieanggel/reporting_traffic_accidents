# Stage 1: Build binary
FROM golang:1.25-alpine AS builder
WORKDIR /app
# Salin fail modul dulu untuk caching layer
COPY go.mod go.sum ./
RUN go mod download
COPY . .
# Bina aplikasi (asumsi fail utama adalah main.go)
RUN go build -o main .

# Stage 2: Run image yang ringan
FROM alpine:latest
WORKDIR /root/
# Ambil fail binary yang sudah siap dari stage builder
COPY --from=builder /app/main .
# Expose port 4000 sesuai konfigurasi kita
EXPOSE 4000
CMD ["./main"]